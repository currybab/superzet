#!/usr/bin/env bash
set -euo pipefail

channel="$1"

if [ "$channel" != "stable" ]; then
  echo "this must be run with the stable release channel" >&2
  exit 1
fi

releases_base_url="${SUPERZET_RELEASES_URL:-https://releases.nangman.ai}"
releases_base_url="${releases_base_url%/}"

curl -fsSL "${releases_base_url}/releases/${channel}/latest/asset?asset=superzet&os=macos&arch=aarch64" \
  | jq -r .version
